# WhatsApp AI Messaging - API Keys Configuration
# Copy this file to '.env' (remove .example) and fill in your API keys

# ===== FREE AI PROVIDERS (Recommended) =====

# Google Gemini API Key (FREE)
# Get your key: https://aistudio.google.com/app/apikey
# Free tier: 60 requests/minute, 1500 requests/day
GOOGLE_API_KEY=your_google_api_key_here

# Groq API Key (FREE - Fastest)
# Get your key: https://console.groq.com
# Free tier: 14,400 requests/day, 30 requests/minute
GROQ_API_KEY=your_groq_api_key_here

# ===== OFFLINE AI (No API key needed) =====

# Ollama (Local/Offline AI)
# Install from: https://ollama.com/download
# Then run: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434

# ===== PAID AI PROVIDERS (Optional) =====

# OpenAI API Key (PAID)
# Get your key: https://platform.openai.com/
# Pricing: https://openai.com/pricing
OPENAI_API_KEY=your_openai_api_key_here

# ===== NOTES =====
# - You only need ONE API key to use the app
# - Groq is recommended (fastest + free)
# - Gemini is also excellent (free + high quality)
# - Ollama works offline but requires download (2-4GB)
# - Never share your API keys publicly!
